# ── Cấu hình backend AgriSmart ──
# Sao chép file này thành ".env" rồi điền khóa API.

# Khóa Gemini API (lấy tại https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# (tùy chọn) model Gemini
GEMINI_MODEL=gemini-2.5-flash

# (tùy chọn) giới hạn chống spam
MAX_CHATS_PER_DAY=20
COOLDOWN_SECONDS=12

# (tùy chọn) đường dẫn file SQLite — mặc định ../db/agrieco.db
# DB_PATH=
